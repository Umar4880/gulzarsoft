# ---------------------------------
# App mode
# ---------------------------------
ENV=dev
DEBUG=false

# ---------------------------------
# PostgreSQL container variables
# ---------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=bravous_app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------
# SQLAlchemy URLs used by backend
# ---------------------------------
APP_DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/bravous_app
CHECKPOINT_DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/bravous_app

# ---------------------------------
# Optional services
# ---------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------
# AI provider settings
# ---------------------------------
GEMINI_API_KEY=
MODEL_NAME=gemini-1.5-flash
TAVILY_SEARCH_API=
